# Database (SQLite — local dev, zero setup)
# SQLite dosyası prisma/ klasöründe oluşur (şema ile aynı dizin)
DATABASE_URL="file:./dev.db"

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Görsel üretim (manken / ayna — şu an stüdyoda gizli, API hazır olunca açılır)
# Listelemek için: node scripts/list-gemini-models.mjs
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
# Yedekler: gemini-3.1-flash-image-preview, gemini-3-pro-image-preview

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Python rembg service (when backend is running)
REMBG_SERVICE_URL="http://localhost:8000"
